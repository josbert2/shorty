# =========================================================
# Shotso — variables de entorno (dev)
# Copialo a .env y completá lo que necesites.
# =========================================================

# ---------- Database ----------
# Default apunta al Postgres del docker-compose.yml de este repo
DATABASE_URL="postgresql://shotso:shotso_dev@localhost:5432/shotso"

# ---------- Auth (Better Auth) ----------
# Generá con: openssl rand -base64 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# ---------- Cloudflare R2 ----------
# Endpoint del account (NO incluye el bucket)
R2_ENDPOINT="https://3e6ad99f885c38e04fe9413fe6462b19.r2.cloudflarestorage.com"
# Bucket donde guardamos uploads y exports
R2_BUCKET="shorty"
# URL pública (custom domain de R2) — sin barra al final
R2_PUBLIC_URL="https://pub-5ad14bf9b5e143b0af5153b86b9e4cea.r2.dev"
# API token con permisos Object Read & Write
# Crear en: Cloudflare dashboard → R2 → Manage R2 API Tokens → Create API token
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""

# ---------- Polar.sh ----------
# Crear organización y access token en https://polar.sh
# Dashboard → Settings → API Tokens → New Token (scope: full)
POLAR_ACCESS_TOKEN=""
# Webhooks → New endpoint → copiá el signing secret
POLAR_WEBHOOK_SECRET=""
# "sandbox" para dev (https://sandbox.polar.sh), "production" para prod
POLAR_SERVER="sandbox"
# Tu organización (slug o ID)
POLAR_ORGANIZATION_ID=""
# Product ID del plan Pro (Dashboard → Products → tu producto)
POLAR_PRO_PRODUCT_ID=""

# ---------- App ----------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
